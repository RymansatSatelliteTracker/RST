{
  "name": "rst",
  "productName": "RST",
  "private": true,
  "type": "module",
  "version": "v0.1.4e",
  "author": {
    "name": "rsp.",
    "email": "xxx@rymansat.com"
  },
  "main": "dist/electron/main/main.js",
  "scripts": {
    "app:dev": "concurrently \"vite\" \"npm:dev:main\" \"electron .\"",
    "dev:main": "concurrently \"tsc -w\" \"tsc-alias -w\"",
    "app:build": "npm run vite:build && tsc && npm run app:import-replace && electron-builder",
    "app:build-win": "npm run vite:build && tsc && npm run app:import-replace && electron-builder --win",
    "app:build-mac": "npm run vite:build && tsc && npm run app:import-replace && electron-builder --mac",
    "app:build-linux": "npm run vite:build && tsc && npm run app:import-replace && electron-builder --linux",
    "app:import-replace": "tsc-alias -p tsconfig.json",
    "app:preview": "npm run vite:build && tsc && npm run app:import-replace && electron .",
    "vite:build": "vue-tsc --noEmit && vite build",
    "vite:dev": "vite",
    "vite:preview": "vite preview",
    "ts": "tsc",
    "watch": "tsc -w",
    "test": "jest --config ./jest.config.json --coverage",
    "test:e2e": "playwright test src/__tests__/playwright",
    "format": "prettier --write ."
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "resolveFullExtension": ".js"
  },
  "build": {
    "appId": "RST",
    "asar": true,
    "directories": {
      "buildResources": "assets",
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "!dist/electron/__tests__"
    ],
    "extraResources": [
      {
        "from": "resources/data/init-data",
        "to": "data/init-data"
      },
      {
        "from": "public/tiles",
        "to": "tiles"
      }
    ],
    "extraMetadata": {
      "main": "dist/electron/main/main.js"
    },
    "mac": {
      "artifactName": "${productName}_${version}_${arch}.${ext}",
      "icon": "public/assets/rst_icon_1024.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "artifactName": "${productName}_${version}.${ext}",
      "icon": "public/assets/rst.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "public/assets/rst.ico",
      "uninstallerIcon": "public/assets/rst.ico"
    },
    "linux": {
      "category": "Utility",
      "icon": "public/assets/rst_icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "deb": {
      "compression": "xz",
      "depends": [
        "libgtk-3-0",
        "libnss3",
        "libxss1",
        "libasound2"
      ]
    }
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "axios": "^1.16.1",
    "dayjs": "^1.11.20",
    "electron-log": "^5.4.4",
    "electron-store": "^8.2.0",
    "geojson": "^0.5.0",
    "leaflet": "^1.9.4",
    "leaflet-arrowheads": "^1.4.0",
    "mitt": "^3.0.1",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^3.2.3",
    "satellite.js": "^6.0.2",
    "serialport": "^12.0.0",
    "vue": "^3.5.34",
    "vuetify": "^3.12.6",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^29.5.14",
    "@types/leaflet": "^1.9.21",
    "@types/serialport": "^8.0.5",
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^8.2.2",
    "electron": "^41.6.1",
    "electron-builder": "^26.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.33.0",
    "jest": "^29.7.0",
    "playwright": ">=1.60.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.9.3",
    "vite": ">=5.4.21",
    "vite-tsconfig-paths": "^5.1.4",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.2.12"
  },
  "volta": {
    "node": "22.18.0"
  }
}
